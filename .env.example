# Environment Configuration for Lingo

# Google Analytics 4
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Web Vitals Endpoint (optional)
NEXT_PUBLIC_WEB_VITALS_ENDPOINT=https://your-analytics-endpoint.com/vitals

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://lingo.com
NEXT_PUBLIC_SITE_NAME=Lingo

# Google Search Console Verification
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your-google-site-verification-code

# Social Media
NEXT_PUBLIC_FACEBOOK_APP_ID=your-facebook-app-id
NEXT_PUBLIC_TWITTER_HANDLE=@lingoapp

# API Keys (server-side only)
# These should be kept secret and not exposed to the client
API_KEY=your-api-key
DATABASE_URL=your-database-url

# Email Configuration
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-email-password
EMAIL_FROM=noreply@lingo.com

# Security
NEXTAUTH_SECRET=your-nextauth-secret
NEXTAUTH_URL=https://lingo.com
